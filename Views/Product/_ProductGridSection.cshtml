@model ProductListViewModel
@{
    var sortOptions = new (string Value, string Label)[]
    {
        ("newest", "Mới nhất"),
        ("price_asc", "Giá: Thấp đến cao"),
        ("price_desc", "Giá: Cao đến thấp"),
        ("name_asc", "Tên: A - Z")
    };
}

@if (Model.Products.Count == 0)
{
    <div class="products-empty">
        <p>@Model.EmptyMessage</p>
    </div>
}
else
{
    <div class="product-toolbar-row">
        <span class="product-result-count">@Model.TotalCount sản phẩm</span>
        <form method="get" asp-action="@Model.ActionName" id="product-sort-form">
            <input type="hidden" name="type" value="@Model.CurrentType" />
            <input type="hidden" name="q" value="@Model.CurrentQuery" />
            <select name="sort" class="product-sort-select" onchange="document.getElementById('product-sort-form').submit()">
                @foreach (var opt in sortOptions)
                {
                    <option value="@opt.Value" selected="@(Model.CurrentSort == opt.Value)">@opt.Label</option>
                }
            </select>
        </form>
    </div>

    <div class="products-grid">
        @foreach (var p in Model.Products)
        {
            @await Html.PartialAsync("_ProductCard", p)
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="product-pagination">
            <a class="product-page-link @(Model.CurrentPage <= 1 ? "disabled" : "")"
               asp-action="@Model.ActionName" asp-route-type="@Model.CurrentType" asp-route-q="@Model.CurrentQuery" asp-route-sort="@Model.CurrentSort" asp-route-page="@(Model.CurrentPage - 1)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            </a>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <a class="product-page-link @(i == Model.CurrentPage ? "active" : "")"
                   asp-action="@Model.ActionName" asp-route-type="@Model.CurrentType" asp-route-q="@Model.CurrentQuery" asp-route-sort="@Model.CurrentSort" asp-route-page="@i">@i</a>
            }
            <a class="product-page-link @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")"
               asp-action="@Model.ActionName" asp-route-type="@Model.CurrentType" asp-route-q="@Model.CurrentQuery" asp-route-sort="@Model.CurrentSort" asp-route-page="@(Model.CurrentPage + 1)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
        </div>
    }
}
