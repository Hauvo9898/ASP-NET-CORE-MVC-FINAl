@model CartViewModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

@if (Model.Items.Count == 0)
{
    <div class="cart-empty">
        <div class="max-w-7xl">
            <h1>Giỏ hàng của bạn đang trống</h1>
            <p>Khám phá các bộ sưu tập mới nhất và tìm điều gì đó đặc biệt.</p>
            <a class="luxury-button" asp-controller="Product" asp-action="Index">Bắt đầu mua sắm</a>
        </div>
    </div>
}
else
{
    <div class="max-w-7xl" style="padding:0 16px">
        <div class="cart-header">
            <h1 class="cart-title">Giỏ hàng của bạn</h1>
            <div class="cart-steps">
                <span class="step active">01. Giỏ hàng</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                <span class="step">02. Thông tin giao hàng</span>
            </div>
        </div>

        <div class="cart-layout">
            <div class="lg-col-2">
                <div class="cart-items">
                    @foreach (var item in Model.Items)
                    {
                        <div class="cart-item">
                            <div class="cart-item-img">
                                <img src="@item.Image" alt="@item.Name" referrerpolicy="no-referrer" onerror="this.src='https://picsum.photos/seed/fashion/800/1000'" />
                            </div>
                            <div class="cart-item-info">
                                <div>
                                    <div style="display:flex;justify-content:space-between;margin-bottom:8px">
                                        <h3 class="cart-item-name">@item.Name</h3>
                                        <p class="cart-item-price">@FormatHelper.FormatPrice(item.Price * item.Quantity)</p>
                                    </div>
                                    <p class="cart-item-cat">
                                        @(item.Size != null ? $"Size {item.Size} " : "")@(item.Color != null ? $"- {item.Color}" : "")
                                    </p>
                                </div>
                                <div class="cart-item-bottom">
                                    <div class="cart-qty-control">
                                        <form asp-controller="Cart" asp-action="UpdateQuantity" method="post">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <input type="hidden" name="size" value="@item.Size" />
                                            <input type="hidden" name="color" value="@item.Color" />
                                            <input type="hidden" name="quantity" value="@(item.Quantity - 1)" />
                                            <button class="cart-qty-btn" type="submit">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                            </button>
                                        </form>
                                        <span class="cart-qty-val">@item.Quantity</span>
                                        <form asp-controller="Cart" asp-action="UpdateQuantity" method="post">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <input type="hidden" name="size" value="@item.Size" />
                                            <input type="hidden" name="color" value="@item.Color" />
                                            <input type="hidden" name="quantity" value="@(item.Quantity + 1)" />
                                            <button class="cart-qty-btn" type="submit">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                            </button>
                                        </form>
                                    </div>
                                    <form asp-controller="Cart" asp-action="Remove" method="post">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <input type="hidden" name="size" value="@item.Size" />
                                        <input type="hidden" name="color" value="@item.Color" />
                                        <button class="cart-remove-btn" type="submit">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="cart-summary">
                <h2 class="cart-summary-title">Đơn hàng của bạn</h2>
                <div class="cart-summary-lines">
                    @foreach (var item in Model.Items)
                    {
                        <div class="cart-summary-line">
                            <span style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@item.Name x@item.Quantity</span>
                            <span>@FormatHelper.FormatPrice(item.Price * item.Quantity)</span>
                        </div>
                    }
                </div>
                <div class="cart-summary-divider"></div>
                <div class="cart-summary-lines">
                    <div class="cart-summary-line"><span>Tạm tính</span><span>@FormatHelper.FormatPrice(Model.TotalPrice)</span></div>
                    <div class="cart-summary-line"><span>Vận chuyển</span><span class="free-ship">MIỄN PHÍ</span></div>
                    <div class="cart-summary-line total"><span style="font-size:12px;align-self:center">Tổng cộng</span><span>@FormatHelper.FormatPrice(Model.TotalPrice)</span></div>
                </div>
                <a class="cart-checkout-btn" asp-controller="Order" asp-action="Checkout" style="text-decoration:none">
                    <span>XÁC NHẬN ĐƠN HÀNG</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
                <div class="cart-icons-row">
                    <div class="cart-icon-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        <span>Security</span>
                    </div>
                    <div class="cart-icon-divider"></div>
                    <div class="cart-icon-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                        <span>Express</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
