@model ContactFormViewModel
@{
    ViewData["Title"] = "Liên hệ & Góp ý";
}

<div class="contact-hero">
    <div class="contact-hero-overlay"></div>
    <div class="contact-hero-content">
        <p class="contact-hero-sub">Kết nối với chúng tôi</p>
        <h1 class="contact-hero-title">Liên hệ &amp; Góp ý</h1>
        <div class="contact-hero-line"></div>
        <p class="contact-hero-desc">Mỗi ý kiến của bạn là nguồn cảm hứng giúp AHU hoàn thiện hơn mỗi ngày.</p>
    </div>
</div>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="max-w-7xl" style="padding:24px 16px 0; text-align:right">
        <a class="oh-detail-btn" style="display:inline-flex" asp-action="MyMessages">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Xem tin nhắn đã gửi &amp; phản hồi
        </a>
    </div>
}

<div class="contact-body max-w-7xl">
    <div class="contact-info-row">
        <div class="contact-info-card">
            <div class="contact-info-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 class="contact-info-title">Showroom</h3>
            <p class="contact-info-text">102/15 Đường Huỳnh Châu Sổ, phường Khánh Hậu<br />TP. Tây Ninh, Việt Nam</p>
            <p class="contact-info-note">Thứ 2 – Thứ 7: 9:00 – 20:00</p>
        </div>
        <div class="contact-info-card">
            <div class="contact-info-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.08 6.08l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <h3 class="contact-info-title">Điện thoại</h3>
            <p class="contact-info-text">+84365273977</p>
            <p class="contact-info-note">Hotline: 1800 8386 (Miễn phí)</p>
        </div>
        <div class="contact-info-card">
            <div class="contact-info-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <h3 class="contact-info-title">Email</h3>
            <p class="contact-info-text">AHU@luxury.com</p>
            <p class="contact-info-note">Phản hồi trong vòng 24 giờ</p>
        </div>
        <div class="contact-info-card">
            <div class="contact-info-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </div>
            <h3 class="contact-info-title">Mạng xã hội</h3>
            <p class="contact-info-text">@@AHU.Luxury</p>
            <p class="contact-info-note">Instagram · Facebook · TikTok</p>
        </div>
    </div>

    <div class="contact-main-row">
        <div class="contact-form-wrap">
            @if (ViewBag.SubmitSuccess == true)
            {
                <div class="contact-success">
                    <div class="contact-success-icon">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <h3 class="contact-success-title">Đã gửi thành công!</h3>
                    <p class="contact-success-desc">Cảm ơn bạn đã liên hệ với AHU. Chúng tôi sẽ phản hồi trong vòng <strong>24 giờ</strong> qua email của bạn.</p>
                    <a class="contact-send-again-btn" asp-action="Index">Gửi tin nhắn khác</a>
                </div>
            }
            else
            {
                <div class="contact-form-header">
                    <div class="contact-form-icon-wrap">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    </div>
                    <div>
                        <h2 class="contact-form-title">Gửi tin nhắn</h2>
                        <p class="contact-form-subtitle">Chúng tôi lắng nghe mọi ý kiến của bạn</p>
                    </div>
                </div>

                <form asp-action="Index" method="post">
                    <div class="contact-topic-row">
                        <button type="button" class="contact-topic-btn active" onclick="selectTopic('gop-y',this)">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            Góp ý
                        </button>
                        <button type="button" class="contact-topic-btn" onclick="selectTopic('ho-tro',this)">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                            Hỗ trợ đơn hàng
                        </button>
                        <button type="button" class="contact-topic-btn" onclick="selectTopic('hop-tac',this)">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            Hợp tác
                        </button>
                        <button type="button" class="contact-topic-btn" onclick="selectTopic('khac',this)">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
                            Khác
                        </button>
                    </div>
                    <input type="hidden" id="ct-topic-input" asp-for="Topic" />

                    <div class="contact-form-body">
                        <div class="contact-form-grid">
                            <div class="contact-field-group">
                                <label class="contact-field-label">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                    Họ và tên <span class="contact-required">*</span>
                                </label>
                                <input asp-for="Name" class="contact-input" placeholder="Nhập tên của bạn..." />
                            </div>
                            <div class="contact-field-group">
                                <label class="contact-field-label">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.08 6.08l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                    Số điện thoại
                                </label>
                                <input asp-for="Phone" type="tel" class="contact-input" placeholder="VD: 09xx xxx xxx" />
                            </div>
                        </div>

                        <div class="contact-field-group">
                            <label class="contact-field-label">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                                Email <span class="contact-required">*</span>
                            </label>
                            <input asp-for="Email" type="email" class="contact-input" placeholder="example@email.com" />
                        </div>

                        <div class="contact-field-group" id="ct-order-field" style="display:none">
                            <label class="contact-field-label">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                                Mã đơn hàng
                            </label>
                            <input asp-for="OrderRef" class="contact-input" placeholder="VD: #ABC123456" />
                        </div>

                        <div class="contact-field-group">
                            <label class="contact-field-label">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                Đánh giá trải nghiệm
                            </label>
                            <div class="contact-rating">
                                <button type="button" class="rating-star" data-val="1" onclick="setRating(1)">★</button>
                                <button type="button" class="rating-star" data-val="2" onclick="setRating(2)">★</button>
                                <button type="button" class="rating-star" data-val="3" onclick="setRating(3)">★</button>
                                <button type="button" class="rating-star" data-val="4" onclick="setRating(4)">★</button>
                                <button type="button" class="rating-star" data-val="5" onclick="setRating(5)">★</button>
                                <span class="rating-label" id="rating-label">Chưa đánh giá</span>
                            </div>
                            <input type="hidden" id="ct-rating-input" asp-for="Rating" />
                        </div>

                        <div class="contact-field-group">
                            <label class="contact-field-label">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                Nội dung <span class="contact-required">*</span>
                            </label>
                            <textarea asp-for="Content" class="contact-textarea" placeholder="Chia sẻ ý kiến, câu hỏi hoặc yêu cầu của bạn..." oninput="updateCharCount(this)" maxlength="500"></textarea>
                            <div class="contact-char-count"><span id="ct-char-count">0</span>/500 ký tự</div>
                        </div>

                        <div asp-validation-summary="ModelOnly" class="contact-error" style="display:block"></div>

                        <button class="contact-submit-btn" type="submit">
                            <span>Gửi tin nhắn</span>
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                        </button>
                    </div>
                </form>
            }
        </div>

        <div class="contact-sidebar">
            <div class="contact-sidebar-card">
                <h3 class="contact-sidebar-title">Giờ làm việc</h3>
                <div class="contact-hours-list">
                    <div class="contact-hours-row"><span class="contact-hours-day">Thứ 2 – Thứ 6</span><span class="contact-hours-time">9:00 – 20:00</span></div>
                    <div class="contact-hours-row"><span class="contact-hours-day">Thứ 7</span><span class="contact-hours-time">9:00 – 18:00</span></div>
                    <div class="contact-hours-row"><span class="contact-hours-day">Chủ nhật</span><span class="contact-hours-time contact-closed">Nghỉ</span></div>
                </div>
            </div>
            <div class="contact-sidebar-card">
                <h3 class="contact-sidebar-title">Cam kết của AHU</h3>
                <ul class="contact-promise-list">
                    <li class="contact-promise-item"><div class="contact-promise-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><span>Phản hồi trong vòng 24 giờ làm việc</span></li>
                    <li class="contact-promise-item"><div class="contact-promise-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><span>Bảo mật thông tin tuyệt đối</span></li>
                    <li class="contact-promise-item"><div class="contact-promise-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><span>Hỗ trợ tận tâm, chuyên nghiệp</span></li>
                    <li class="contact-promise-item"><div class="contact-promise-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><span>Ghi nhận mọi góp ý để cải thiện</span></li>
                </ul>
            </div>
        </div>
    </div>
</div>
