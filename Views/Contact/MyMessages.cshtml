@model List<Feedback>
@{
    ViewData["Title"] = "Tin nhắn của tôi";
    var topicLabels = new Dictionary<string, string> { ["gop-y"] = "Góp ý", ["ho-tro"] = "Hỗ trợ đơn hàng", ["hop-tac"] = "Hợp tác", ["khac"] = "Khác" };
}

<div class="max-w-6xl" style="padding:40px 16px">
    <a class="oh-back-link" asp-controller="Account" asp-action="Profile">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Quay lại thông tin tài khoản
    </a>

    <div style="margin-bottom:40px">
        <h1 class="oh-title" style="font-size:2.25rem">Tin nhắn của tôi</h1>
        <div class="oh-subtitle">
            <div class="oh-subtitle-line"></div>
            <p class="oh-subtitle-text">Các cuộc hội thoại qua Liên hệ &amp; Góp ý</p>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="oh-empty">
            <div class="oh-empty-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#e5e7eb" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h3 class="oh-empty-title">Chưa có tin nhắn nào</h3>
            <p class="oh-empty-desc">Bạn chưa gửi tin nhắn nào qua trang Liên hệ &amp; Góp ý.</p>
            <a class="luxury-button" asp-action="Index">Gửi tin nhắn ngay</a>
        </div>
    }
    else
    {
        <div class="chat-thread-list">
            @foreach (var f in Model)
            {
                var last = f.Messages.OrderByDescending(m => m.SentAt).FirstOrDefault();
                var hasUnreadAdminReply = f.Messages.Any(m => m.SenderRole == "admin") && last?.SenderRole == "admin";
                <a class="chat-thread-row" asp-action="Thread" asp-route-id="@f.Id">
                    <div class="chat-thread-row-left">
                        <span class="chat-thread-topic">@(!string.IsNullOrEmpty(f.Topic) ? topicLabels.GetValueOrDefault(f.Topic, "Khác") : "Liên hệ")</span>
                        <p class="chat-thread-preview">@(last?.SenderRole == "admin" ? "AHU: " : "")@(last?.Content ?? f.Content)</p>
                        <p class="chat-thread-date">@(last?.SentAt ?? f.Date).ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    @if (hasUnreadAdminReply)
                    {
                        <span class="chat-unread-dot" title="Có phản hồi mới"></span>
                    }
                </a>
            }
        </div>
    }
</div>
