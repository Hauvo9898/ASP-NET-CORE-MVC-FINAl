@model List<Order>
@{
    ViewData["Title"] = "Đơn hàng";
    string q = ViewBag.CurrentQuery ?? "";
    string? NextStatus(string s) => s switch { "pending" => "processing", "processing" => "shipped", "shipped" => "delivered", _ => null };
    string NextLabel(string s) => s switch { "processing" => "Duyệt đơn", "shipped" => "Bắt đầu giao", "delivered" => "Đã giao xong", _ => "" };
}

<div class="admin-tab-header">
    <div class="admin-search-wrap">
        <span class="admin-search-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
        <form method="get" asp-action="Index">
            <input type="text" name="q" class="admin-search" value="@q" placeholder="Tìm theo mã đơn, tên khách hoặc SĐT..." onchange="this.form.submit()" />
        </form>
    </div>
</div>

<div class="admin-table-wrap">
    <div style="overflow-x:auto">
        <table class="admin-table">
            <thead><tr><th>Vận đơn</th><th>Khách hàng</th><th>Giá trị</th><th>Trạng thái</th><th>Ngày đặt</th><th style="text-align:right">Chi tiết</th></tr></thead>
            <tbody>
                @foreach (var o in Model)
                {
                    var next = NextStatus(o.Status);
                    <tr>
                        <td>
                            <div class="mono gold-text" style="font-size:10px;font-weight:700">#@o.Id.ToString("D6")</div>
                            <div style="font-size:8px;color:#9ca3af;text-transform:uppercase">Hóa đơn điện tử</div>
                        </td>
                        <td>
                            <p style="font-weight:600">@o.Name</p>
                            <p style="font-size:10px;color:#9ca3af;font-family:monospace">@o.Phone</p>
                        </td>
                        <td style="font-weight:700;letter-spacing:0.1em">@FormatHelper.FormatPrice(o.Total)</td>
                        <td><span class="status-pill @FormatHelper.StatusBadgeClass(o.Status)">@FormatHelper.StatusLabel(o.Status)</span></td>
                        <td style="font-size:12px;color:#9ca3af">@o.Date.ToString("dd/MM/yyyy")</td>
                        <td style="text-align:right">
                            <div class="admin-row-actions" style="opacity:1">
                                @if (next != null)
                                {
                                    <form asp-action="UpdateStatus" method="post" style="display:inline">
                                        <input type="hidden" name="id" value="@o.Id" />
                                        <input type="hidden" name="status" value="@next" />
                                        <button class="admin-action-btn approve" type="submit" title="@NextLabel(next)">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                        </button>
                                    </form>
                                }
                                <a class="admin-action-btn view" asp-action="Details" asp-route-id="@o.Id" title="Xem chi tiết">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (Model.Count == 0)
        {
            <div style="padding:80px;text-align:center;color:#9ca3af;font-style:italic">Chưa có đơn hàng nào.</div>
        }
    </div>
</div>
