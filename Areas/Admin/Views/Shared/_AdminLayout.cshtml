@using AHUWeb.Helpers
@using AHUWeb.Data
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@{
    var activeTab = ViewData["ActiveTab"] as string ?? "overview";
    var displayName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Admin";

    // Dong bo voi [RequirePermission] o controller: tra cuu truc tiep tu CSDL (khong dung
    // Session cache) de menu luon dung ngay sau khi admin doi Nhom quyen cua tai khoan,
    // khong can doi tai khoan do dang xuat/dang nhap lai. Neu tai khoan chua gan Group nao
    // thi coi nhu khong gioi han - hien du menu nhu cu.
    HashSet<string>? permCodes = null;
    var idClaim = User.FindFirstValue(ClaimTypes.NameIdentifier);
    if (int.TryParse(idClaim, out var currentUserId))
    {
        var groupId = await Db.Users.Where(u => u.Id == currentUserId).Select(u => u.GroupId).FirstOrDefaultAsync();
        if (groupId.HasValue)
        {
            permCodes = (await Db.GroupPermissions
                .Where(gp => gp.GroupId == groupId.Value)
                .Select(gp => gp.Permission!.Code)
                .ToListAsync()).ToHashSet();
        }
    }
    bool HasPerm(string code) => permCodes == null || permCodes.Contains(code);
}
<!doctype html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - Quản trị AHU" : "Quản trị AHU")</title>
    <link rel="stylesheet" href="~/css/style.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<div class="admin-page-root" style="padding-top:96px;min-height:100vh;background:#f9fafb;">
    <div class="admin-layout">
        <aside class="admin-sidebar">
            <div class="admin-sidebar-header">
                <h2 class="admin-sidebar-title">Hệ thống QTV</h2>
                <p class="admin-sidebar-user">Quản trị viên: <span>@displayName</span></p>
            </div>
            <nav class="admin-nav">
                <a class="admin-nav-btn @(activeTab == "overview" ? "active" : "")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                    Tổng quan
                </a>
                @if (HasPerm("Product.Manage"))
                {
                    <a class="admin-nav-btn @(activeTab == "products" ? "active" : "")" asp-area="Admin" asp-controller="Products" asp-action="Index">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                        Sản phẩm
                    </a>
                }
                @if (HasPerm("Order.Manage"))
                {
                    <a class="admin-nav-btn @(activeTab == "orders" ? "active" : "")" asp-area="Admin" asp-controller="Orders" asp-action="Index">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                        Đơn hàng
                    </a>
                }
                <a class="admin-nav-btn @(activeTab == "categories" ? "active" : "")" asp-area="Admin" asp-controller="Categories" asp-action="Index">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    Danh mục
                </a>
                @if (HasPerm("Group.Manage"))
                {
                    <a class="admin-nav-btn @(activeTab == "groups" ? "active" : "")" asp-area="Admin" asp-controller="Groups" asp-action="Index">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        Nhóm quyền
                    </a>
                }
                @if (HasPerm("User.Manage"))
                {
                    <a class="admin-nav-btn @(activeTab == "users" ? "active" : "")" asp-area="Admin" asp-controller="Users" asp-action="Index">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        Người dùng
                    </a>
                }
                @if (HasPerm("Article.Manage"))
                {
                    <a class="admin-nav-btn @(activeTab == "articles" ? "active" : "")" asp-area="Admin" asp-controller="Articles" asp-action="Index">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                        Tin tức
                    </a>
                }
                @if (HasPerm("Staff.Manage"))
                {
                    <a class="admin-nav-btn @(activeTab == "staffs" ? "active" : "")" asp-area="Admin" asp-controller="Staffs" asp-action="Index">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        Nhân viên
                    </a>
                }
                <a class="admin-nav-btn @(activeTab == "reports" ? "active" : "")" asp-area="Admin" asp-controller="Dashboard" asp-action="Reports">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    Báo cáo doanh thu
                </a>
                @if (HasPerm("Feedback.Manage"))
                {
                    <a class="admin-nav-btn @(activeTab == "contacts" ? "active" : "")" asp-area="Admin" asp-controller="Feedbacks" asp-action="Index">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        Liên hệ &amp; Góp ý
                    </a>
                }
                @if (HasPerm("Forum.Manage"))
                {
                    <a class="admin-nav-btn @(activeTab == "forum" ? "active" : "")" asp-area="Admin" asp-controller="Forum" asp-action="Index">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
                        Diễn đàn
                    </a>
                }
            </nav>
            <div class="admin-sidebar-footer">
                <a class="admin-config-btn" asp-area="" asp-controller="Home" asp-action="Index">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                    Về trang chủ AHU
                </a>
                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                    <button class="admin-config-btn" type="submit" style="width:100%;border:none;background:none;cursor:pointer">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Đăng xuất
                    </button>
                </form>
            </div>
        </aside>

        <main class="admin-main">
            @RenderBody()
        </main>
    </div>
</div>

<div id="toast">
    <span id="toast-icon"></span>
    <span id="toast-msg"></span>
</div>
<form id="af-token-form" style="display:none">@Html.AntiForgeryToken()</form>

<script src="~/js/site.js"></script>
@if (TempData["ToastMessage"] != null)
{
    <script>document.addEventListener('DOMContentLoaded', function(){ showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastMessage"]))); });</script>
}
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>