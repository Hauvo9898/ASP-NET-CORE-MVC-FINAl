@model ProductFormViewModel
@{
    var palette = ((string Name, string Hex)[])ViewBag.ColorPalette;
    var sizeOptions = (string[])ViewBag.SizeOptions;
    var shoeSizeOptions = (string[])ViewBag.ShoeSizeOptions;
}

<div asp-validation-summary="All" class="auth-error" style="display:block;margin-bottom:16px"></div>

<div class="checkout-grid">
    <div class="checkout-input-group">
        <label class="checkout-input-label">Tên sản phẩm</label>
        <input asp-for="Name" class="checkout-input" placeholder="VD: Áo khoác dạ len cao cấp" />
    </div>
    <div class="checkout-input-group">
        <label class="checkout-input-label">Loại sản phẩm</label>
        <select asp-for="Type" class="checkout-input">
            <option value="quần áo">Quần áo</option>
            <option value="phụ kiện">Phụ kiện</option>
            <option value="giày dép">Giày dép</option>
        </select>
    </div>
</div>

<div class="checkout-grid">
    <div class="checkout-input-group">
        <label class="checkout-input-label">Giá bán (VND)</label>
        <input asp-for="Price" type="number" step="1000" min="0" class="checkout-input" />
    </div>
    <div class="checkout-input-group">
        <label class="checkout-input-label">Giá gốc (VND, để trống nếu không KM)</label>
        <input asp-for="OriginalPrice" type="number" step="1000" min="0" class="checkout-input" />
    </div>
</div>

<div class="checkout-grid">
    <div class="checkout-input-group">
        <label class="checkout-input-label">Khuyến mãi (%)</label>
        <input asp-for="Discount" type="number" min="0" max="100" class="checkout-input" />
    </div>
    <div class="checkout-input-group">
        <label class="checkout-input-label">Tồn kho</label>
        <input asp-for="Stock" type="number" min="0" class="checkout-input" />
    </div>
</div>

<div class="checkout-input-group" style="margin-bottom:24px">
    <label class="checkout-input-label">Mô tả sản phẩm</label>
    <textarea asp-for="Description" class="contact-textarea" rows="3"></textarea>
</div>

<div class="checkout-input-group" style="margin-bottom:24px">
    <label class="checkout-input-label">Đường dẫn ảnh (URL)</label>
    <input asp-for="ImageUrl" class="checkout-input" placeholder="https://..." />
    <label class="checkout-input-label" style="margin-top:12px">... hoặc tải ảnh lên (sẽ ưu tiên nếu chọn)</label>
    <input asp-for="ImageFile" type="file" accept="image/*" class="checkout-input" />
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="preview" style="width:80px;height:100px;object-fit:cover;margin-top:8px;border:1px solid #eee" />
    }
</div>

<div style="margin-bottom:24px" id="sizes-clothing">
    <p class="modal-section-label">Kích cỡ (quần áo / phụ kiện)</p>
    <div class="size-btns">
        @foreach (var s in sizeOptions)
        {
            var checkedAttr = Model.SelectedSizes.Contains(s) ? "checked" : "";
            <label class="size-btn @(Model.SelectedSizes.Contains(s) ? "active" : "")" style="cursor:pointer">
                <input type="checkbox" name="SelectedSizes" value="@s" @checkedAttr style="display:none" onclick="this.parentElement.classList.toggle('active')" />
                @s
            </label>
        }
    </div>
</div>

<div style="margin-bottom:24px" id="sizes-shoes">
    <p class="modal-section-label">Size giày</p>
    <div class="size-btns">
        @foreach (var s in shoeSizeOptions)
        {
            var checkedAttr = Model.SelectedSizes.Contains(s) ? "checked" : "";
            <label class="size-btn @(Model.SelectedSizes.Contains(s) ? "active" : "")" style="cursor:pointer">
                <input type="checkbox" name="SelectedSizes" value="@s" @checkedAttr style="display:none" onclick="this.parentElement.classList.toggle('active')" />
                @s
            </label>
        }
    </div>
</div>

<script>
    // Loại "giày dép" dùng size giày; các loại còn lại dùng size chữ.
    // Khi ĐỔI loại thì bỏ chọn nhóm bị ẩn để không lưu lẫn size áo với size giày;
    // lúc mở form lần đầu chỉ ẩn/hiện, giữ nguyên size đã lưu của sản phẩm.
    (function () {
        var typeSelect = document.getElementById('Type');
        var clothing = document.getElementById('sizes-clothing');
        var shoes = document.getElementById('sizes-shoes');
        function applyVisibility() {
            var isShoes = typeSelect.value === 'giày dép';
            clothing.style.display = isShoes ? 'none' : '';
            shoes.style.display = isShoes ? '' : 'none';
            return isShoes;
        }
        typeSelect.addEventListener('change', function () {
            var isShoes = applyVisibility();
            var hiddenGroup = isShoes ? clothing : shoes;
            hiddenGroup.querySelectorAll('input[type=checkbox]').forEach(function (cb) {
                cb.checked = false;
                cb.parentElement.classList.remove('active');
            });
        });
        applyVisibility();
    })();
</script>

<div style="margin-bottom:24px">
    <p class="modal-section-label">Màu sắc</p>
    <div class="color-btns">
        @foreach (var c in palette)
        {
            var isSelected = Model.SelectedColors.Contains(c.Name);
            <label class="color-btn @(isSelected ? "active" : "")" style="background:@c.Hex;cursor:pointer" title="@c.Name">
                <input type="checkbox" name="SelectedColors" value="@c.Name" @(isSelected ? "checked" : "") style="display:none" onclick="this.parentElement.classList.toggle('active')" />
            </label>
        }
    </div>
</div>

<div style="display:flex;gap:32px;margin-bottom:24px">
    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px">
        <input asp-for="IsActive" type="checkbox" style="width:16px;height:16px" />
        Hiển thị trên cửa hàng
    </label>
    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px">
        <input asp-for="Featured" type="checkbox" style="width:16px;height:16px" />
        Sản phẩm nổi bật
    </label>
    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px">
        <input asp-for="IsComingSoon" type="checkbox" style="width:16px;height:16px" />
        Sắp ra mắt
    </label>
</div>
