@model List<ForumPost>
@{
    ViewData["Title"] = "Diễn đàn";
    string currentFilter = ViewBag.CurrentFilter ?? "pending";
    int pendingCount = ViewBag.PendingCount ?? 0;
}

<div class="admin-tab-header">
    <div class="acm-topic-filters" style="display:flex; gap:8px">
        <a class="acm-filter-btn @(currentFilter == "pending" ? "active" : "")" asp-action="Index" asp-route-filter="pending">Chờ duyệt (@pendingCount)</a>
        <a class="acm-filter-btn @(currentFilter == "approved" ? "active" : "")" asp-action="Index" asp-route-filter="approved">Đã duyệt</a>
        <a class="acm-filter-btn @(currentFilter == "rejected" ? "active" : "")" asp-action="Index" asp-route-filter="rejected">Đã từ chối</a>
        <a class="acm-filter-btn @(currentFilter == "all" ? "active" : "")" asp-action="Index" asp-route-filter="all">Tất cả</a>
    </div>
</div>

<div class="admin-table-wrap">
    <div style="overflow-x:auto">
        <table class="admin-table">
            <thead><tr><th>Tác giả</th><th>Nội dung</th><th>Ảnh</th><th>Tương tác</th><th>Trạng thái</th><th>Ngày đăng</th><th style="text-align:right">Thao tác</th></tr></thead>
            <tbody>
                @foreach (var p in Model)
                {
                    var authorName = p.User?.FullName ?? p.User?.Username ?? "Người dùng đã xóa";
                    <tr>
                        <td>
                            <div style="display:flex; align-items:center; gap:10px">
                                <div class="user-initial-avatar">@(authorName.Length > 0 ? authorName[0].ToString().ToUpper() : "?")</div>
                                <span style="font-size:13px; font-weight:500">@authorName</span>
                            </div>
                        </td>
                        <td style="max-width:280px">
                            <p style="font-size:12px; color:#4b5563; overflow:hidden; text-overflow:ellipsis; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical">@p.Content</p>
                        </td>
                        <td>
                            @if (p.Images.Count > 0)
                            {
                                <div style="display:flex; gap:4px">
                                    <img src="@p.Images.First().ImagePath" style="width:40px;height:40px;object-fit:cover" referrerpolicy="no-referrer" />
                                    @if (p.Images.Count > 1)
                                    {
                                        <span style="font-size:10px; color:#9ca3af; align-self:center">+@(p.Images.Count - 1)</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span style="color:#d1d5db; font-size:11px">—</span>
                            }
                        </td>
                        <td style="font-size:11px; color:#9ca3af">
                            @p.Reactions.Count reaction · @p.Comments.Count bình luận
                        </td>
                        <td>
                            <span class="order-status-badge @FormatHelper.ForumStatusBadgeClass(p.Status)">@FormatHelper.ForumStatusLabel(p.Status)</span>
                            @if (p.IsPinned)
                            {
                                <div style="margin-top:4px"><span class="order-status-badge" style="color:var(--luxury-gold-antique);background:#faf8f4;border-color:#e9dcc0;font-size:9px">Đã ghim</span></div>
                            }
                        </td>
                        <td style="font-size:11px; color:#9ca3af">@p.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td style="text-align:right">
                            <div class="admin-row-actions" style="opacity:1; flex-wrap:wrap; justify-content:flex-end">
                                <a class="admin-action-btn view" asp-controller="Forum" asp-action="Details" asp-area="" asp-route-id="@p.Id" title="Xem chi tiết / bình luận" target="_blank">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                </a>
                                @if (p.Status != "approved")
                                {
                                    <form asp-action="Approve" method="post" style="display:inline">
                                        <input type="hidden" name="id" value="@p.Id" /><input type="hidden" name="filter" value="@currentFilter" />
                                        <button class="admin-action-btn approve" type="submit" title="Duyệt bài"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></button>
                                    </form>
                                }
                                @if (p.Status != "rejected")
                                {
                                    <form asp-action="Reject" method="post" style="display:inline" onsubmit="return confirm('Từ chối bài viết này?')">
                                        <input type="hidden" name="id" value="@p.Id" /><input type="hidden" name="filter" value="@currentFilter" />
                                        <button class="admin-action-btn del" type="submit" title="Từ chối"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
                                    </form>
                                }
                                <form asp-action="TogglePin" method="post" style="display:inline">
                                    <input type="hidden" name="id" value="@p.Id" /><input type="hidden" name="filter" value="@currentFilter" />
                                    <button class="admin-action-btn edit" type="submit" title="@(p.IsPinned ? "Bỏ ghim" : "Ghim bài")"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="17" x2="12" y2="22"/><path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z"/></svg></button>
                                </form>
                                <form asp-action="Delete" method="post" style="display:inline" onsubmit="return confirm('Xóa vĩnh viễn bài viết này?')">
                                    <input type="hidden" name="id" value="@p.Id" /><input type="hidden" name="filter" value="@currentFilter" />
                                    <button class="admin-action-btn del" type="submit" title="Xóa"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (Model.Count == 0)
        {
            <div style="padding:80px;text-align:center;color:#9ca3af;font-style:italic">Không có bài viết nào trong mục này.</div>
        }
    </div>
</div>
