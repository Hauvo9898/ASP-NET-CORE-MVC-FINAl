@using System.Security.Claims
@model List<User>
@{
    ViewData["Title"] = "Người dùng";
    string q = ViewBag.CurrentQuery ?? "";
    int currentUserId = int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier)!);
}

<div class="admin-tab-header">
    <div class="admin-search-wrap">
        <span class="admin-search-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
        <form method="get" asp-action="Index">
            <input type="text" name="q" class="admin-search" value="@q" placeholder="Tìm theo tên, username, email..." onchange="this.form.submit()" />
        </form>
    </div>
    <a class="admin-add-btn" asp-action="Create">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Thêm hội viên
    </a>
</div>

<div class="admin-table-wrap">
    <div style="overflow-x:auto">
        <table class="admin-table">
            <thead><tr><th>ID</th><th>Họ tên</th><th>Email / Tài khoản</th><th>Vai trò</th><th>Trạng thái</th><th style="text-align:right">Biên tập</th></tr></thead>
            <tbody>
                @foreach (var u in Model)
                {
                    var displayName = !string.IsNullOrWhiteSpace(u.FullName) ? u.FullName! : u.Username;
                    <tr>
                        <td><span style="font-family:monospace;font-size:10px;color:#9ca3af">#@u.Id.ToString("D4")</span></td>
                        <td>
                            <div style="display:flex;align-items:center;gap:12px">
                                <div class="user-initial-avatar">@(displayName.Length > 0 ? displayName[0].ToString().ToUpper() : "?")</div>
                                <span style="font-size:14px;font-weight:500">@displayName</span>
                            </div>
                        </td>
                        <td>
                            <div style="font-size:12px;color:#4b5563">@(u.Email ?? "—")</div>
                            <div style="font-size:9px;color:#9ca3af;text-transform:uppercase">@@@u.Username</div>
                        </td>
                        <td>
                            @if (u.Role == "admin")
                            {
                                <span class="user-role-admin"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>Quản trị viên</span>
                            }
                            else
                            {
                                <span class="user-role-user"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>Khách hàng</span>
                            }
                        </td>
                        <td>
                            @if (u.IsLocked)
                            {
                                <span class="user-status-locked"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>Đã khóa</span>
                            }
                            else
                            {
                                <span class="user-status-active"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Hoạt động</span>
                            }
                        </td>
                        <td style="text-align:right">
                            <div class="admin-row-actions">
                                <a class="admin-action-btn edit" asp-action="Edit" asp-route-id="@u.Id"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></a>
                                @if (u.Id == currentUserId)
                                {
                                    <button class="admin-action-btn" type="button" disabled title="Không thể tự khóa chính mình" style="opacity:0.35;cursor:not-allowed"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></button>
                                }
                                else if (u.IsLocked)
                                {
                                    <form asp-action="ToggleLock" asp-route-id="@u.Id" method="post" onsubmit="return confirm('Mở khóa tài khoản này?')">
                                        <button class="admin-action-btn unlock" type="submit" title="Mở khóa"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 9.9-3.4"/></svg></button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="ToggleLock" asp-route-id="@u.Id" method="post" onsubmit="return confirm('Khóa tài khoản này?')">
                                        <button class="admin-action-btn del" type="submit" title="Khóa"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (Model.Count == 0)
        {
            <div style="padding:80px;text-align:center;color:#9ca3af;font-style:italic">Không tìm thấy người dùng nào.</div>
        }
    </div>
</div>