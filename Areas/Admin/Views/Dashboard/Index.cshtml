@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Tổng quan";
}

<div class="admin-stats-grid">
    <div class="stat-card">
        <div class="stat-card-header"><span class="stat-card-label">Doanh thu</span><span class="stat-icon gold"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></span></div>
        <div class="stat-value">@FormatHelper.FormatPrice(Model.TotalRevenue)</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-header"><span class="stat-card-label">Giao dịch</span><span class="stat-icon green"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></span></div>
        <div class="stat-value">@Model.TotalOrders</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-header"><span class="stat-card-label">Hội viên</span><span class="stat-icon blue"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></span></div>
        <div class="stat-value">@Model.TotalUsers</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-header"><span class="stat-card-label">Sản phẩm đã bán</span><span class="stat-icon orange"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></span></div>
        <div class="stat-value">@Model.TotalProductsSold</div>
    </div>
</div>

<div class="admin-section-card" style="margin-bottom:32px">
    <div class="admin-section-header">
        <div>
            <p class="admin-section-title">Đơn hàng mới nhất</p>
            <p class="admin-section-sub">Các giao dịch gần đây nhất cần xử lý</p>
        </div>
        <a class="admin-see-all" asp-controller="Orders" asp-action="Index">
            Xem tất cả
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
    </div>
    <div style="overflow-x:auto">
        <table class="admin-table">
            <thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Giá trị</th><th>Trạng thái</th><th>Thời gian</th><th style="text-align:right">Thao tác</th></tr></thead>
            <tbody>
                @if (Model.RecentOrders.Count == 0)
                {
                    <tr><td colspan="6" style="text-align:center;padding:40px;color:#9ca3af;font-style:italic">Chưa có đơn hàng nào.</td></tr>
                }
                else
                {
                    @foreach (var o in Model.RecentOrders)
                    {
                        <tr>
                            <td class="mono gold-text">#@o.Id.ToString("D6")</td>
                            <td><p style="font-weight:600;font-size:13px">@o.Name</p></td>
                            <td style="font-weight:700;font-size:13px">@FormatHelper.FormatPrice(o.Total)</td>
                            <td><span class="status-pill @FormatHelper.StatusBadgeClass(o.Status)">@FormatHelper.StatusLabel(o.Status)</span></td>
                            <td style="font-size:10px;color:#9ca3af">@o.Date.ToString("HH:mm dd/MM")</td>
                            <td style="text-align:right">
                                <a class="admin-action-btn view" asp-controller="Orders" asp-action="Details" asp-route-id="@o.Id"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="admin-section-card">
    <p class="admin-section-title" style="margin-bottom:24px">Đơn hàng theo trạng thái</p>
    <div class="admin-stats-grid">
        @foreach (var kv in Model.OrdersByStatus)
        {
            <div class="stat-card">
                <div class="stat-card-header"><span class="stat-card-label">@FormatHelper.StatusLabel(kv.Key)</span></div>
                <div class="stat-value">@kv.Value</div>
            </div>
        }
    </div>
</div>
