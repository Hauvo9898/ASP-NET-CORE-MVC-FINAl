@model List<Article>
@{
    ViewData["Title"] = "Tin tức";
    string q = ViewBag.CurrentQuery ?? "";
}

<div class="admin-tab-header">
    <div class="admin-search-wrap">
        <span class="admin-search-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
        <form method="get" asp-action="Index">
            <input type="text" name="q" class="admin-search" value="@q" placeholder="Tìm kiếm bài viết..." onchange="this.form.submit()" />
        </form>
    </div>
    <a class="admin-add-btn" asp-action="Create">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Thêm bài viết
    </a>
</div>

<div class="admin-table-wrap">
    <div style="overflow-x:auto">
        <table class="admin-table">
            <thead><tr><th>Bài viết</th><th>Chuyên mục</th><th style="text-align:right">Biên tập</th></tr></thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:16px">
                                <img class="product-thumb" src="@a.Image" referrerpolicy="no-referrer" onerror="this.src='https://picsum.photos/seed/news/200/300'" />
                                <p style="font-size:14px;font-weight:600;color:#1A1A1A">@a.Title</p>
                            </div>
                        </td>
                        <td>@a.Category</td>
                        <td style="text-align:right">
                            <div class="admin-row-actions">
                                <a class="admin-action-btn edit" asp-action="Edit" asp-route-id="@a.Id"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></a>
                                <form asp-action="Delete" asp-route-id="@a.Id" method="post" onsubmit="return confirm('Xóa bài viết này?')">
                                    <button class="admin-action-btn del" type="submit"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (Model.Count == 0)
        {
            <div style="padding:80px;text-align:center;color:#9ca3af;font-style:italic">Chưa có bài viết nào.</div>
        }
    </div>
</div>
